// Prisma schema for Taiti - Game Points Tracker

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Core models for game tracking

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  games         Game[]
  playerScores  PlayerScore[]
}

model Game {
  id          String   @id @default(cuid())
  name        String
  maxPlayers  Int      @default(4)  // 4 for now, 3 in future
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  ownerId      String
  owner        User         @relation(fields: [ownerId], references: [id])
  players      Player[]
  rounds       Round[]
  playerScores PlayerScore[]
}

model Player {
  id        String   @id @default(cuid())
  name      String
  position  Int      // 1, 2, 3, 4
  gameId    String
  createdAt DateTime @default(now())

  // Relations
  game         Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)
  scores       Score[]
  playerScores PlayerScore[]
}

model Round {
  id        String   @id @default(cuid())
  number    Int
  gameId    String
  winnerId  String?  // Player who won (0 cards)
  createdAt DateTime @default(now())

  // Relations
  game   Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  scores Score[]
}

model Score {
  id               String   @id @default(cuid())
  cardsLeft        Int      // X = total cards left
  twosLeft         Int      // N = number of "2" cards
  calculatedPoints Int      // (X - N + N*5) * multiplier
  multiplier       Int      // 1, 2, 3, or 4
  roundId          String
  playerId         String
  createdAt        DateTime @default(now())

  // Relations
  round  Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model PlayerScore {
  id           String   @id @default(cuid())
  totalPoints  Int      @default(0)
  rank         Int?
  gameId       String
  playerId     String
  userId       String?
  updatedAt    DateTime @updatedAt

  // Relations
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@unique([gameId, playerId])
}
